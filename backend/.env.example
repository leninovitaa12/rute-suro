# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# TomTom API (Optional, for future enhancements)
TOMTOM_API_KEY=your-tomtom-api-key

# FastAPI Settings
DEBUG=True
PORT=8000
HOST=0.0.0.0

# Map Data
MAP_DATA_PATH=./data/map_data.json

# A* Algorithm Settings
MAX_SNAP_DISTANCE_M=500
MAX_SPEED_KPH=70
TURN_THRESHOLD_DEG=25
STRONG_TURN_THRESHOLD_DEG=60

# Traffic Sync (for background task)
SYNC_INTERVAL_MINUTES=30
CONGESTION_TTL_MINUTES=45
MAX_GRID_POINTS=45
GRID_CELL_DEG=0.005
RETRY_WAIT_SEC=60
RETRY_MAX=5
